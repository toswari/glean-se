# Database Configuration
WEAVIATE_URL=http://localhost:8080

# LLM Provider Selection
# Options: openai (default), clarifai (see CLARIFAI.md), alibaba (see ALIBABA.md)
LLM_PROVIDER=alibaba

# Alibaba Cloud Model Studio OpenAI-Compatible Configuration (Required when LLM_PROVIDER=alibaba)
# Get API key from https://modelstudio.console.alibabacloud.com/ap-southeast-1?tab=doc#/apikey
# IMPORTANT: Replace with your actual API key from the console
ALIBABA_API_KEY=your-alibaba-api-key

# Alibaba base URL - using international endpoint (recommended)
ALIBABA_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Model Selection
# Choose which model alias to use for both ingestion and agent
# Available models: qwen-turbo, qwen-plus, qwen-max, qwen2.5-72b-instruct, qwen3.5-flash
LLM_CHOICE=qwen3.5-flash

# Embedding Model
# Available models: text-embedding-v2, text-embedding-v3
EMBEDDING_MODEL=text-embedding-v3

# Development Settings
LOG_LEVEL=DEBUG
DEBUG_MODE=true
TOKENIZERS_PARALLELISM=false
